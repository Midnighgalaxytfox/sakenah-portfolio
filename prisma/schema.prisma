generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/sakenah_portfolio/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model QuizQuestion {
  id                Int      @id @default(autoincrement())
  slug              String   @unique
  category          String
  subcategory       String?
  difficulty        String   @default("medium")
  question          String
  options           Json
  correctIndex      Int
  explanation       String
  wrongExplanations Json
  xpReward          Int      @default(10)
  createdAt         DateTime @default(now())
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}
