# Copy this file to .env for local development.
# Never commit your real .env file to GitHub.

# Required for Prisma/PostgreSQL features: quiz questions and contact submissions.
# Example local Postgres URL:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/sakenah_portfolio?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Required for Sakura AI chat and the AI career recommender.
# Keep this secret server-side only.
ABACUSAI_API_KEY="your_abacus_ai_api_key_here"
